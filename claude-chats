            QListWidget::item { padding: 6px 12px; border-bottom: 1px solid #161b22; }
            QListWidget::item:selected { background: #1d4ed8; color: #fff; }
            QListWidget::item:hover:!selected { background: #161b22; }
        """)
        self.chat_list.currentItemChanged.connect(self._on_selected)
        ll.addWidget(self.chat_list)

        self.list_footer = QLabel()
        self.list_footer.setFixedHeight(26)
        self.list_footer.setStyleSheet(
            "padding: 0 12px; color: #484f58; font-size: 11px;"
            "border-top: 1px solid #21262d;"
        )
        ll.addWidget(self.list_footer)
        splitter.addWidget(left)

        self.viewer = ChatViewer()
        self.viewer.setStyleSheet("background: #0d1117; color: #c9d1d9;")
        splitter.addWidget(self.viewer)

        splitter.setSizes([320, 780])
        layout.addWidget(splitter)

    def _combo_style(self):
        return """
            QComboBox {
                background: #161b22; border: 1px solid #30363d; color: #c9d1d9;
                padding: 4px 8px; border-radius: 5px; font-size: 11px; min-width: 130px;
            }
            QComboBox::drop-down { border: none; }
            QComboBox QAbstractItemView {
                background: #161b22; color: #c9d1d9; border: 1px solid #30363d;
                selection-background-color: #1d4ed8;
            }
        """

    def refresh_models(self, chats):
        current = self.model_combo.currentData()
        self.model_combo.blockSignals(True)
        self.model_combo.clear()
        self.model_combo.addItem("Todos los modelos", None)
        for m in sorted({c['model'] for c in chats if c['model'] != 'unknown'}):
            self.model_combo.addItem(m.replace('claude-', ''), m)
        idx = self.model_combo.findData(current)
        if idx >= 0:
            self.model_combo.setCurrentIndex(idx)
        self.model_combo.blockSignals(False)

    def _apply_filters(self):
        chats = self._get_chats()
        query = self.search.text().lower().strip()
        model_f = self.model_combo.currentData()
        date_f = self.date_combo.currentData()

        if query:
            chats = [c for c in chats if
                     query in c['title'].lower() or
                     any(query in m['text'].lower() for m in c['messages'])]
        if model_f:
            chats = [c for c in chats if c['model'] == model_f]
        if date_f:
            cutoff = (datetime.now() - date_f).timestamp()
            chats = [c for c in chats if c['mtime'] >= cutoff]

        self._render_list(chats, self.group_btn.isChecked())

    def _render_list(self, chats, group=False):
        self.chat_list.clear()
        if group:
            groups = defaultdict(list)
            for c in chats:
                groups[c['project_display']].append(c)
            for proj in sorted(groups):
                hdr = QListWidgetItem(f"  {proj}  ({len(groups[proj])})")
                hdr.setFlags(Qt.ItemFlag.NoItemFlags)
                hdr.setForeground(QColor('#484f58'))
                hdr.setSizeHint(QSize(0, 26))
                f = QFont()
                f.setPointSize(9)
                hdr.setFont(f)
                self.chat_list.addItem(hdr)
                for c in groups[proj]:
                    self.chat_list.addItem(ChatListItem(c))
        else:
            for c in chats:
                self.chat_list.addItem(ChatListItem(c))
        n = len(chats)
        self.list_footer.setText(f"  {n} conversación{'es' if n != 1 else ''}")

    def _on_selected(self, current, _):
        if isinstance(current, ChatListItem):
            self.viewer.load_chat(current.chat)


# ─── Main window ──────────────────────────────────────────────────────────────

class MainWindow(QMainWindow):
    def __init__(self):
        super().__init__()
        self.all_chats = []
        self.setWindowTitle("Claude Chats")
        self.setMinimumSize(860, 580)
        self.resize(1150, 720)
        self._setup_ui()
        self._load_chats()

    def _setup_ui(self):
        central = QWidget()
        self.setCentralWidget(central)
        layout = QVBoxLayout(central)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(0)

        topbar = QWidget()
        topbar.setFixedHeight(46)
        topbar.setStyleSheet("background: #010409; border-bottom: 1px solid #21262d;")
        tb = QHBoxLayout(topbar)
        tb.setContentsMargins(16, 0, 16, 0)

        lbl = QLabel("Claude Chats")
        lbl.setStyleSheet("font-size: 15px; font-weight: bold; color: #e6edf3;")
        tb.addWidget(lbl)
        tb.addStretch()

        refresh_btn = QPushButton("↻ Actualizar")
        refresh_btn.clicked.connect(self._load_chats)
        refresh_btn.setStyleSheet("""
            QPushButton {
                background: #21262d; color: #c9d1d9; border: 1px solid #30363d;
                padding: 5px 12px; border-radius: 5px; font-size: 12px;
            }
            QPushButton:hover { background: #30363d; }
        """)
        tb.addWidget(refresh_btn)
        layout.addWidget(topbar)

        self.tabs = QTabWidget()
        self.tabs.setStyleSheet("""
            QTabWidget::pane { border: none; }
            QTabBar::tab {
                background: #010409; color: #8b949e; border: none;
                padding: 8px 20px; font-size: 12px;
            }
            QTabBar::tab:selected { color: #e6edf3; border-bottom: 2px solid #388bfd; }
            QTabBar::tab:hover:!selected { color: #c9d1d9; }
        """)

        self.chats_tab = ChatsTab(lambda: self.all_chats)
        self.chats_tab.setStyleSheet("background: #0d1117;")
        self.tabs.addTab(self.chats_tab, "Chats")

        self.usage_tab = UsageTab()
        self.usage_tab.setStyleSheet("background: #0d1117;")
        self.tabs.addTab(self.usage_tab, "Uso")

        layout.addWidget(self.tabs)

        statusbar = QWidget()
        statusbar.setFixedHeight(26)
        statusbar.setStyleSheet("background: #010409; border-top: 1px solid #21262d;")
        sb = QHBoxLayout(statusbar)
        sb.setContentsMargins(16, 0, 16, 0)
        self.status_label = QLabel()
        self.status_label.setStyleSheet("color: #484f58; font-size: 11px;")
        sb.addWidget(self.status_label)
        layout.addWidget(statusbar)

        self.setStyleSheet("background: #0d1117; color: #c9d1d9;")

    def _load_chats(self):
        self.all_chats = load_all_chats()
        self.chats_tab.refresh_models(self.all_chats)
        self.chats_tab._apply_filters()
        self.usage_tab.refresh(self.all_chats)
        total_in = sum(c['input_tokens'] for c in self.all_chats)
        total_out = sum(c['output_tokens'] for c in self.all_chats)
        total_cost = sum(c['cost'] for c in self.all_chats)
        self.status_label.setText(
            f"{len(self.all_chats)} chats  ·  "
            f"↑ {total_in:,}  ↓ {total_out:,} tokens  ·  "
            f"costo total estimado: ${total_cost:.4f}"
        )


def main():
    app = QApplication(sys.argv)
    app.setApplicationName("Claude Chats")
    window = MainWindow()
    window.show()
    sys.exit(app.exec())


if __name__ == '__main__':
    main()
