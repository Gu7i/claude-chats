class ChatListItem(QListWidgetItem):
    def __init__(self, chat):
        super().__init__()
        self.chat = chat
        title = chat['title'][:55] + ('…' if len(chat['title']) > 55 else '')
        preview = chat['last_assistant'][:65] + ('…' if len(chat['last_assistant']) > 65 else '')
        model_short = chat['model'].replace('claude-', '').replace('-', ' ')
        dur = f"  ·  {chat['duration_str']}" if chat['duration_str'] else ''
        line3 = f"{chat['date_str']}  ·  {chat['msg_count']} msgs  ·  {model_short}{dur}"
        self.setText(f"{title}\n{preview}\n{line3}" if preview else f"{title}\n{line3}")
        self.setSizeHint(QSize(0, 76 if preview else 54))


