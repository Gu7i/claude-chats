PROJECTS_DIR = Path.home() / '.claude/projects'

PRICING = {
    'claude-sonnet-4-6': (3.0, 15.0),
    'claude-opus-4-8': (5.0, 25.0),
    'claude-opus-4-7': (5.0, 25.0),
    'claude-opus-4-6': (5.0, 25.0),
    'claude-fable-5': (10.0, 50.0),
    'claude-haiku-4-5': (1.0, 5.0),
}


def estimate_cost(model, input_tokens, output_tokens):
    prices = PRICING.get(model, (3.0, 15.0))
    return (input_tokens * prices[0] + output_tokens * prices[1]) / 1_000_000


def get_birth_time(path):
    try:
        r = subprocess.run(['stat', '-c', '%W', str(path)],
                           capture_output=True, text=True, timeout=2)
        t = int(r.stdout.strip())
        return t if t > 0 else None
    except Exception:
        return None


def load_all_chats():
    chats = []
    if not PROJECTS_DIR.exists():
        return chats
    for proj_dir in PROJECTS_DIR.iterdir():
        if not proj_dir.is_dir():
            continue
        for jsonl_file in proj_dir.glob('*.jsonl'):
            chat = parse_chat(jsonl_file)
            if chat:
                chats.append(chat)
    return sorted(chats, key=lambda c: c['mtime'], reverse=True)


def parse_chat(path):
    first_user = None
    last_assistant = None
    messages = []
    input_tokens = 0
    output_tokens = 0
    model = None

    try:
        with open(path, encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    d = json.loads(line)
                except Exception:
                    continue

                msg = d.get('message', {})
                role = msg.get('role', '')
                content = msg.get('content', '')
                usage = msg.get('usage', {})

                text = ''
                if isinstance(content, list):
                    for c in content:
                        if isinstance(c, dict) and c.get('type') == 'text':
                            t = c.get('text', '').strip()
                            if t:
                                text = t
                                break
                elif isinstance(content, str):
                    text = content.strip()

                if role == 'user' and text and not text.startswith('<'):
                    if first_user is None:
                        first_user = text
                    messages.append({'role': 'user', 'text': text})
                elif role == 'assistant' and text:
                    messages.append({'role': 'assistant', 'text': text})
                    last_assistant = text
                    if not model and msg.get('model'):
                        model = msg['model']

                if usage:
                    input_tokens += (usage.get('input_tokens', 0) +
                                     usage.get('cache_creation_input_tokens', 0))
                    output_tokens += usage.get('output_tokens', 0)
    except Exception:
        return None

    if not first_user:
        return None

    stat = path.stat()
    cost = estimate_cost(model or '', input_tokens, output_tokens)

    birth = get_birth_time(path)
    duration_str = ''
    if birth:
        secs = int(stat.st_mtime - birth)
        if secs >= 60:
            mins = secs // 60
            duration_str = f"{mins // 60}h {mins % 60}m" if mins >= 60 else f"{mins} min"

    raw = path.parent.name
    display = raw.lstrip('-').replace('-', '/')
    if display.startswith('home/'):
        parts = display.split('/', 2)
        display = '~' if len(parts) < 3 else '~/' + parts[2]

    return {
        'id': path.stem,
        'path': str(path),
        'project': raw,
        'project_display': display or '~',
        'title': first_user,
        'last_assistant': (last_assistant or '')[:120],
        'messages': messages,
        'mtime': stat.st_mtime,
        'date': datetime.fromtimestamp(stat.st_mtime).date(),
        'date_str': datetime.fromtimestamp(stat.st_mtime).strftime('%d %b %H:%M'),
        'msg_count': len(messages),
        'input_tokens': input_tokens,
        'output_tokens': output_tokens,
        'cost': cost,
        'model': model or 'unknown',
        'duration_str': duration_str,
    }


def _md_to_html(text):
    doc = QTextDocument()
    doc.setMarkdown(text)
    full_html = doc.toHtml()
    m = re.search(r'<body[^>]*>(.*?)</body>', full_html, re.DOTALL)
    return m.group(1) if m else f'<p>{text}</p>'


