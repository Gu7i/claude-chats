class UsageTab(QWidget):
    def __init__(self):
        super().__init__()
        layout = QVBoxLayout(self)
        layout.setContentsMargins(16, 16, 16, 16)
        layout.setSpacing(12)

        title = QLabel("Uso de tokens — últimos 30 días")
        title.setStyleSheet("font-size: 13px; font-weight: bold; color: #e6edf3;")
        layout.addWidget(title)

        legend = QWidget()
        leg_layout = QHBoxLayout(legend)
        leg_layout.setContentsMargins(0, 0, 0, 0)
        for color, text in [('#1d4ed8', 'Input'), ('#7c3aed', 'Output')]:
            dot = QLabel('●')
            dot.setStyleSheet(f"color: {color}; font-size: 14px;")
            lbl = QLabel(text)
            lbl.setStyleSheet("color: #8b949e; font-size: 11px; margin-right: 12px;")
            leg_layout.addWidget(dot)
            leg_layout.addWidget(lbl)
        leg_layout.addStretch()
        layout.addWidget(legend)

        self.chart = TokenChart()
        self.chart.setStyleSheet("background: #0d1117; border-radius: 8px;")
        layout.addWidget(self.chart)

        grid = QWidget()
        grid_layout = QHBoxLayout(grid)
        grid_layout.setContentsMargins(0, 0, 0, 0)
        grid_layout.setSpacing(8)
        self._stat_vals = {}
        for key, label in [
            ('chats', 'Chats'), ('input', 'Tokens entrada'),
            ('output', 'Tokens salida'), ('cost', 'Costo estimado'),
        ]:
            card = QWidget()
            card.setStyleSheet("background: #161b22; border-radius: 8px;")
            cl = QVBoxLayout(card)
            cl.setContentsMargins(14, 10, 14, 10)
            val = QLabel('—')
            val.setStyleSheet("font-size: 20px; font-weight: bold; color: #e6edf3;")
            lbl = QLabel(label)
            lbl.setStyleSheet("font-size: 10px; color: #484f58;")
            cl.addWidget(val)
            cl.addWidget(lbl)
            grid_layout.addWidget(card)
            self._stat_vals[key] = val
        layout.addWidget(grid)

        model_title = QLabel("Por modelo")
        model_title.setStyleSheet("font-size: 12px; font-weight: bold; color: #8b949e; margin-top: 4px;")
        layout.addWidget(model_title)

        self.model_breakdown = QLabel()
        self.model_breakdown.setStyleSheet(
            "color: #6b7280; font-size: 11px; font-family: monospace;"
        )
        self.model_breakdown.setWordWrap(True)
        layout.addWidget(self.model_breakdown)
        layout.addStretch()

    def refresh(self, chats):
        self.chart.set_data(chats)

        total_in = sum(c['input_tokens'] for c in chats)
        total_out = sum(c['output_tokens'] for c in chats)
        total_cost = sum(c['cost'] for c in chats)

        def fmt(n):
            if n >= 1_000_000:
                return f'{n / 1_000_000:.1f}M'
            if n >= 1_000:
                return f'{n / 1_000:.1f}K'
            return str(n)

        self._stat_vals['chats'].setText(str(len(chats)))
        self._stat_vals['input'].setText(fmt(total_in))
        self._stat_vals['output'].setText(fmt(total_out))
        self._stat_vals['cost'].setText(f'${total_cost:.4f}')

        by_model = defaultdict(lambda: {'count': 0, 'cost': 0.0})
        for c in chats:
            by_model[c['model']]['count'] += 1
            by_model[c['model']]['cost'] += c['cost']

        lines = []
        for model, data in sorted(by_model.items(), key=lambda x: -x[1]['cost']):
            m = model.replace('claude-', '')
            lines.append(f"  {m:<30} {data['count']:>3} chats   ${data['cost']:.4f}")
        self.model_breakdown.setText('\n'.join(lines))


