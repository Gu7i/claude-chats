            f"↑ {chat['input_tokens']:,}  ↓ {chat['output_tokens']:,} tokens",
            f"${chat['cost']:.4f}" if chat['cost'] > 0 else None,
            chat['duration_str'] or None,
            chat['model'],
        ]
        self.stats_label.setText('  ·  '.join(p for p in parts if p))

    def _copy_id(self):
        if self.current_chat:
            QApplication.clipboard().setText(self.current_chat['id'])

    def _copy_cmd(self):
        if self.current_chat:
            QApplication.clipboard().setText(f"claude --resume {self.current_chat['id']}")

    def _export_md(self):
        if not self.current_chat:
            return
        chat = self.current_chat
        name = chat['title'][:40].replace('/', '-').replace('\n', ' ') + '.md'
        path, _ = QFileDialog.getSaveFileName(
            self, "Exportar chat", str(Path.home() / name), "Markdown (*.md)"
        )
        if not path:
            return
        lines = [
            f"# {chat['title']}\n",
            f"**ID:** `{chat['id']}`  ",
            f"**Fecha:** {chat['date_str']}  ",
            f"**Modelo:** {chat['model']}  ",
            f"**Tokens:** ↑ {chat['input_tokens']:,}  ↓ {chat['output_tokens']:,}",
            "", "---", "",
        ]
        for msg in chat['messages']:
            role = "**Vos:**" if msg['role'] == 'user' else "**Claude:**"
            lines.append(f"{role}\n\n{msg['text']}\n\n---\n")
        Path(path).write_text('\n'.join(lines), encoding='utf-8')

    def _open_konsole(self):
        if not self.current_chat:
            return
        sid = self.current_chat['id']
        env = os.environ.copy()
        local_bin = str(Path.home() / '.local/bin')
        if local_bin not in env.get('PATH', ''):
            env['PATH'] = f"{local_bin}:{env.get('PATH', '')}"
        # bash -c '...; bash' keeps the terminal open after claude exits
        subprocess.Popen(
            ['konsole', '-e', 'bash', '-c', f'claude --resume {sid}; bash'],
            env=env
        )


# ─── Token usage chart ────────────────────────────────────────────────────────

class TokenChart(QWidget):
    def __init__(self):
        super().__init__()
        self._data = {}
        self.setMinimumHeight(180)
        self.setSizePolicy(QSizePolicy.Policy.Expanding, QSizePolicy.Policy.Fixed)

    def set_data(self, chats):
        self._data = defaultdict(lambda: {'input': 0, 'output': 0})
        cutoff = date.today() - timedelta(days=29)
        for chat in chats:
            if chat['date'] >= cutoff:
                self._data[chat['date']]['input'] += chat['input_tokens']
                self._data[chat['date']]['output'] += chat['output_tokens']
        self.update()

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.RenderHint.Antialiasing)

        w, h = self.width(), self.height()
        pl, pr, pt, pb = 52, 16, 20, 36

        today = date.today()
        days = [today - timedelta(days=29 - i) for i in range(30)]
        max_val = max(
            (self._data[d]['input'] + self._data[d]['output']
             for d in days if d in self._data),
            default=1
        )

        chart_w = w - pl - pr
        chart_h = h - pt - pb
        slot = chart_w / 30
        bar_w = max(3, slot - 3)

        painter.setPen(QPen(QColor('#1e293b'), 1))
        for i in range(5):
            y = int(pt + i * chart_h / 4)
            painter.drawLine(pl, y, w - pr, y)

        for i, d in enumerate(days):
            if d not in self._data:
                continue
            x = int(pl + i * slot)
            in_h = int(self._data[d]['input'] / max_val * chart_h)
            out_h = int(self._data[d]['output'] / max_val * chart_h)
            if out_h > 0:
                painter.fillRect(x, pt + chart_h - in_h - out_h, int(bar_w), out_h,
                                 QColor('#7c3aed'))
            if in_h > 0:
                painter.fillRect(x, pt + chart_h - in_h, int(bar_w), in_h,
                                 QColor('#1d4ed8'))

        font = QFont()
        font.setPointSize(8)
        painter.setFont(font)
        painter.setPen(QPen(QColor('#4b5563'), 1))
        for i, d in enumerate(days):
            if i % 7 == 0 or i == 29:
                x = int(pl + i * slot)
                painter.drawText(x - 12, h - 4, d.strftime('%d/%m'))

        painter.setPen(QPen(QColor('#6b7280'), 1))
        for i in range(5):
            val = int(max_val * (4 - i) / 4)
            y = int(pt + i * chart_h / 4)
            label = f'{val // 1000}K' if val >= 1000 else str(val)
            painter.drawText(0, y - 6, pl - 4, 16, Qt.AlignmentFlag.AlignRight, label)

        painter.end()


